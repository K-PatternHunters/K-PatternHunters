# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Qdrant
QDRANT_URL=http://qdrant:6333

# Redis (used by Celery)
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development
SECRET_KEY=your-secret-key-here

# ── MongoDB ─────────────────────────────────
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=ga4_ecommerce
MONGO_COLLECTION=events

# ── BigQuery ─────────────────────────────────
# GCP 프로젝트 ID (서비스 계정이 속한 프로젝트)
BQ_PROJECT_ID=

# BigQuery 데이터셋 (공개 샘플 데이터셋 기준)
BQ_DATASET=bigquery-public-data.ga4_obfuscated_sample_ecommerce

# 적재할 날짜 범위 (YYYYMMDD)
BQ_DATE_START=20210115
BQ_DATE_END=20210131

# 한 번에 MongoDB에 삽입할 문서 수
BQ_BATCH_SIZE=2000

INGEST_WORKERS=6
BQ_CHUNK_DAYS=7

# 서비스 계정 키 파일 경로 (호스트 기준)
SA_KEY_PATH=

# ── RAG ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
CHUNK_MAX_CHARS=1000
CHUNK_OVERLAP=100
EMBED_BATCH_SIZE=50
