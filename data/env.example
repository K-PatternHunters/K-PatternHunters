# ── MongoDB ─────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=secret
MONGO_DB=ga4_ecommerce
MONGO_COLLECTION=events

# ── BigQuery ─────────────────────────────────
# GCP 프로젝트 ID (서비스 계정이 속한 프로젝트)
BQ_PROJECT_ID=your-gcp-project-id

# BigQuery 데이터셋 (공개 샘플 데이터셋 기준)
BQ_DATASET=bigquery-public-data.ga4_obfuscated_sample_ecommerce

# 적재할 날짜 범위 (YYYYMMDD)
BQ_DATE_START=20201101
BQ_DATE_END=20210131

# 한 번에 MongoDB에 삽입할 문서 수
BQ_BATCH_SIZE=500

# 서비스 계정 키 파일 경로 (호스트 기준)
SA_KEY_PATH=./secrets/sa-key.json
